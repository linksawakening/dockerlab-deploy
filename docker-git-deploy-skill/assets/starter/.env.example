# docker-git-deploy deployment environment.
# Copy to .env on the production host and fill in real values.
# NEVER commit .env — it is gitignored.

# --- autoheal ---
AUTOHEAL_IMAGE=willfarrell/autoheal:latest
# Watch only containers labeled "autoheal=true". Use "all" to watch every
# container that defines a healthcheck.
AUTOHEAL_CONTAINER_LABEL=autoheal
# Seconds between health polls.
AUTOHEAL_INTERVAL=5
# Grace period (s) after a container starts before it may be restarted.
AUTOHEAL_START_PERIOD=0
# Stop timeout (s) when restarting an unhealthy container.
AUTOHEAL_DEFAULT_STOP_TIMEOUT=10
# Timezone used for log timestamps.
TZ=UTC
