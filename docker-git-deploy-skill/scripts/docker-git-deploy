#!/bin/bash
set -euo pipefail

# docker-git-deploy — CLI for docker-git-deploy

CONFIG_FILE="/etc/docker-git-deploy/config"

log() { echo "[docker-git-deploy] $*"; }
fail() { log "ERROR: $*"; exit 1; }

load_config() {
    [[ -f "$CONFIG_FILE" ]] || fail "Not installed. Run install.sh first."
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
}

require_deployment_dir() {
    load_config
    [[ -d "$DEPLOYMENT_DIR" ]] || fail "Deployment directory $DEPLOYMENT_DIR does not exist"
    cd "$DEPLOYMENT_DIR"
}

cmd_deploy() {
    require_deployment_dir

    log "Fetching origin..."
    git fetch origin

    CURRENT_HEAD="$(git rev-parse HEAD)"
    REMOTE_HEAD="$(git rev-parse origin/main)"

    if [[ "$CURRENT_HEAD" == "$REMOTE_HEAD" && "${1:-}" != "--force" ]]; then
        log "No changes on origin/main. Current: $CURRENT_HEAD"
        exit 0
    fi

    log "New commit detected: $CURRENT_HEAD -> $REMOTE_HEAD"
    git reset --hard "$REMOTE_HEAD"

    log "Validating compose configuration..."
    docker compose config >/dev/null || fail "docker compose config failed"

    log "Pulling images..."
    docker compose pull

    log "Applying stack..."
    docker compose up -d --remove-orphans

    log "Deploy complete. Active commit: $REMOTE_HEAD"
}

cmd_validate() {
    require_deployment_dir
    docker compose config >/dev/null && echo "Valid"
}

cmd_test() {
    require_deployment_dir
    local keep=false
    [[ "${1:-}" == "--keep" ]] && keep=true

    log "Starting stack for smoke test..."
    docker compose up -d

    cleanup() {
        if [[ "$keep" != true ]]; then
            log "Tearing down..."
            docker compose down
        fi
    }
    trap cleanup EXIT

    log "Waiting 5s..."
    sleep 5

    log "Containers:"
    docker compose ps

    log "Smoke test complete."
}

cmd_logs() {
    require_deployment_dir
    docker compose logs "$@"
}

cmd_status() {
    require_deployment_dir
    docker compose ps
}

cmd_help() {
    cat <<EOF
Usage: docker-git-deploy <command> [options]

Commands:
  deploy [--force]      Pull deployment repo and apply changes
  validate              Validate compose configuration
  test [--keep]         Smoke test the stack locally (tears down by default)
  logs [service]        Show compose logs
  status                Show running containers
  help                  Show this help
EOF
}

main() {
    [[ $# -eq 0 ]] && { cmd_help; exit 0; }
    case "$1" in
        deploy) shift; cmd_deploy "$@" ;;
        validate) cmd_validate ;;
        test) shift; cmd_test "$@" ;;
        logs) shift; cmd_logs "$@" ;;
        status) cmd_status ;;
        help|-h|--help) cmd_help ;;
        *) fail "Unknown command: $1" ;;
    esac
}

main "$@"
